{
  "name": "maisum",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "gen:types": "npx supabase gen types typescript --local > packages/shared/src/types/supabase.ts",
    "db:start": "npx supabase start",
    "db:stop": "npx supabase stop",
    "db:reset": "npx supabase db reset"
  },
  "devDependencies": {
    "brace-expansion": "1.1.13",
    "postcss": "8.5.15",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0"
  },
  "packageManager": "npm@11.8.0",
  "dependencies": {
    "puppeteer": "^24.40.0",
    "styled-jsx": "^5.1.7"
  },
  "overrides": {
    "brace-expansion": "1.1.13",
    "postcss": "8.5.15",
    "minimatch@3.1.5": {
      "brace-expansion": "1.1.13"
    },
    "next": {
      "postcss": "8.5.15"
    },
    "next@15.5.18": {
      "postcss": "8.5.15"
    }
  }
}
